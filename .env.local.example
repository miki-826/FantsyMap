# Supabase（未設定の場合はブラウザのローカル保存で動作します）
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# AI深掘り・伝説化・画像生成（未設定の場合は強化テンプレート／グラデーションで動作します）
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# 空想カードの画像生成（任意）
# dall-e-3 は本人確認不要で安定。gpt-image-2 は高品質だが組織認証が必要な場合あり
OPENAI_IMAGE_MODEL=dall-e-3
OPENAI_IMAGE_SIZE=1024x1024
# OPENAI_IMAGE_QUALITY は gpt-image系のみ有効（low/medium/high/auto）
OPENAI_IMAGE_QUALITY=low
